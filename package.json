{
  "name": "jmoney",
  "version": "2.0.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "startc": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "apk": "cd android && NODE_ENV=production ./gradlew assembleRelease",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "prepare": "husky",
    "prebuild": "npx expo prebuild --platform android --clean",
    "dapk": "npx expo run:android",
    "exapk": "npx eas build -p android --profile preview"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/jest-setup.ts"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "moduleNameMapper": {
      "^expo-sqlite$": "<rootDir>/__mocks__/expo-sqlite.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|@shopify/flash-list|@expo/vector-icons)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@shopify/flash-list": "2.0.2",
    "@supabase/supabase-js": "^2.110.1",
    "date-fns": "^4.4.0",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-keep-awake": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-local-authentication": "~57.0.0",
    "expo-location": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-quick-actions": "^6.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.4",
    "@types/react-native-vector-icons": "^6.4.18",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "babel-jest": "^30.3.0",
    "babel-preset-expo": "~57.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.1.0",
    "ts-jest": "^29.4.9",
    "typescript": "~6.0.3"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
